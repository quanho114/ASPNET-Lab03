@model List<BookListItemViewModel>

@{
    ViewData["Title"] = "Book Catalog";
    var totalItems = Model.Count;
}

<div class="page-header">
    <div>
        <h2 class="page-title">Danh mục Sách</h2>
        <p class="page-description">Quản lý danh sách sách mẫu sử dụng Partial Views.</p>
    </div>

    <div style="display: flex; gap: 10px;">
        <a class="btn btn-secondary"
           asp-controller="Books"
           asp-action="Search">
            🔍 Tìm kiếm
        </a>

        <a class="btn"
           asp-controller="Books"
           asp-action="Create">
            ➕ Thêm mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">
        🎉 @TempData["SuccessMessage"]
    </div>
}

<div class="info-box" style="margin-bottom: 12px;">
    📊 <strong>Tổng số sách hiện tại:</strong> @totalItems đầu sách.
</div>

@* Dynamic High-Performance Client-Side Stock Pills Filtering Row *@
<div style="display: flex; gap: 8px; margin-bottom: 16px; align-items: center; flex-wrap: wrap;">
    <span style="font-size: 13px; font-weight: 600; color: #475569; margin-right: 4px;">🔍 Lọc nhanh kho:</span>
    <button class="filter-pill active" onclick="filterStatus('Tất cả', this)">Tất cả (@Model.Count)</button>
    <button class="filter-pill" onclick="filterStatus('Còn hàng', this)">Còn hàng (@Model.Count(b => b.StockStatus == "Còn hàng"))</button>
    <button class="filter-pill" onclick="filterStatus('Cần nhập thêm', this)">Sắp hết (@Model.Count(b => b.StockStatus == "Cần nhập thêm"))</button>
    <button class="filter-pill" onclick="filterStatus('Hết hàng', this)">Hết hàng (@Model.Count(b => b.StockStatus == "Hết hàng"))</button>
</div>

@if (Model.Count == 0)
{
    <p style="color: #64748b;">Chưa có cuốn sách nào trong hệ thống.</p>
}
else
{
    <div class="product-grid">
        @foreach (var item in Model)
        {
            <partial name="_BookCard" model="item" />
        }
    </div>
}

@section Scripts {
    <script>
        function filterStatus(status, element) {
            // Update active state of pill buttons
            document.querySelectorAll('.filter-pill').forEach(pill => pill.classList.remove('active'));
            element.classList.add('active');
            
            // Filter card elements based on their data-status attribute
            const cards = document.querySelectorAll('.product-card');
            cards.forEach(card => {
                if (status === 'Tất cả' || card.getAttribute('data-status') === status) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
}
