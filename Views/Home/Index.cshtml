@{
    ViewData["Title"] = "Trang chủ";
}

<div class="lab-hero" style="padding: 28px 36px; margin-bottom: 20px;">
    <h1 style="font-size: 26px; margin-bottom: 6px;">Mini Inventory Product Catalog.</h1>
    <p style="font-size: 14.5px; opacity: 0.9; line-height: 1.5;">Bài thực hành xây dựng ứng dụng ASP.NET Core MVC quản lý danh mục sản phẩm, nâng cấp giao diện bằng Layout, Partial Views, Tag Helpers và Model Binding.</p>
</div>

<div class="info-box home-goal" style="padding: 12px 18px; margin-bottom: 28px; font-size: 14px;">
    <strong>Mục tiêu bài lab:</strong> 
    <span>Ứng dụng <strong>Layout</strong>, <strong>Partial View</strong>, <strong>Tag Helpers</strong>, và <strong>Model Binding</strong> GET/POST để hoàn thiện website quản lý kho hàng chuyên nghiệp.</span>
</div>

<h3 style="font-size: 18px; font-weight: 600; margin: 36px 0 16px; color: #0f172a; text-align: center;">Luồng hoạt động chính của ứng dụng</h3>
<ul class="flow-list" style="margin-bottom: 36px;">
    <li style="padding: 16px 14px; min-height: 110px;">
        <span style="width: 30px; height: 30px; min-width: 30px; font-size: 13px;">1</span>
        <p style="font-size: 13px; line-height: 1.45;">User gửi request tới URL mong muốn (ví dụ: <code>/Products</code>, <code>/Products/Search</code>).</p>
    </li>
    <li style="padding: 16px 14px; min-height: 110px;">
        <span style="width: 30px; height: 30px; min-width: 30px; font-size: 13px;">2</span>
        <p style="font-size: 13px; line-height: 1.45;"><strong>Controller</strong> tiếp nhận request và tự động thực hiện <strong>Model Binding</strong> từ Query/Form.</p>
    </li>
    <li style="padding: 16px 14px; min-height: 110px;">
        <span style="width: 30px; height: 30px; min-width: 30px; font-size: 13px;">3</span>
        <p style="font-size: 13px; line-height: 1.45;">Controller gọi <strong>ProductService</strong> xử lý lấy dữ liệu từ cơ sở dữ liệu mẫu trong bộ nhớ.</p>
    </li>
    <li style="padding: 16px 14px; min-height: 110px;">
        <span style="width: 30px; height: 30px; min-width: 30px; font-size: 13px;">4</span>
        <p style="font-size: 13px; line-height: 1.45;">Dữ liệu kết quả được chuyển đổi sang các lớp <strong>ViewModel</strong> để bảo mật và tối ưu giao diện.</p>
    </li>
    <li style="padding: 16px 14px; min-height: 110px;">
        <span style="width: 30px; height: 30px; min-width: 30px; font-size: 13px;">5</span>
        <p style="font-size: 13px; line-height: 1.45;">Trả về <strong>Razor View</strong>, kết xuất mã HTML thông qua <strong>Layout</strong> và <strong>Partial Views</strong>.</p>
    </li>
</ul>

<div style="text-align: center; margin-top: 48px; margin-bottom: 24px;">
    <a class="btn btn-lg" style="padding: 12px 24px; font-size: 15px;" asp-controller="Products" asp-action="Index">Đi đến Danh mục Sản phẩm →</a>
</div>
